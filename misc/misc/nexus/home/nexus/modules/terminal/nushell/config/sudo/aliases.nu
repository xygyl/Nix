alias su = sudo -i
alias reboot = sudo su -c 'reboot'
alias poweroff = sudo su -c 'poweroff'
alias sleep = sudo su -c 'systemctl sleep'
alias hibernate = sudo su -c 'systemctl hibernate'
alias hybrid-sleep = sudo su -c 'systemctl hybrid-sleep'
alias suspend-then-hibernate = sudo su -c 'systemctl suspend-then-hibernate'
